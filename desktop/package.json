{
  "name": "vibe-dashcam-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "build:core": "pyinstaller --noconfirm --onefile --name vibe-dashcam-core --distpath src-tauri/bin --workpath src-tauri/target/pyinstaller --specpath src-tauri/target/pyinstaller ../vibe_dashcam/vibe_dashcam.py",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 1420",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.1",
    "lucide-react": "1.23.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.11.4",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "typescript": "5.9.3",
    "vite": "8.1.3"
  }
}
