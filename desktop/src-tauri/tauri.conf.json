{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vibe-Dashcam",
  "version": "0.1.0",
  "identifier": "com.munable.vibedashcam",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:core && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Vibe-Dashcam",
        "width": 336,
        "height": 420,
        "minWidth": 320,
        "minHeight": 420,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "shadow": true,
        "skipTaskbar": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ],
    "resources": {
      "bin/vibe-dashcam-core.exe": "vibe-dashcam-core.exe"
    }
  }
}
